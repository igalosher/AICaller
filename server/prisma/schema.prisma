generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  pending
  in_call
  sold
  callback
  refused
  blacklisted
}

enum ContactSex {
  male
  female
}

enum CallStatus {
  dialing
  ringing
  connected
  ended
  failed
  no_answer
  busy
}

enum CallOutcome {
  none
  sold
  refused
  callback
  no_answer
}

model Contact {
  id         String        @id @default(cuid())
  firstName  String
  familyName String        @default("")
  phone      String        @unique
  sex        ContactSex    @default(male)
  status    ContactStatus @default(pending)
  notes     String?
  deletedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  calls     Call[]
}

model Call {
  id             String                @id @default(cuid())
  contactId      String
  contact        Contact               @relation(fields: [contactId], references: [id])
  flowVersionId  String?
  callFlow       CallFlow?             @relation(fields: [flowVersionId], references: [id])
  status         CallStatus            @default(dialing)
  outcome        CallOutcome           @default(none)
  externalCallId String?
  currentStage      String?
  currentSubflowId  String?
  currentNodeId     String?
  contextJson       String                @default("{}")
  summary        String?
  startedAt      DateTime              @default(now())
  endedAt        DateTime?
  durationSec    Int?
  transcript     CallTranscriptSegment[]
}

model CallTranscriptSegment {
  id             String                   @id @default(cuid())
  callId         String
  call           Call                     @relation(fields: [callId], references: [id], onDelete: Cascade)
  speaker        String
  text           String
  flowNodeId     String?
  timestamp      DateTime                 @default(now())
  classification UtteranceClassification?
}

model Intent {
  id                    String                    @id
  labelHe               String
  descriptionHe         String                    @default("")
  category              String                    @default("general")
  active                Boolean                   @default(true)
  confidenceThreshold   Float                     @default(0.7)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  examples              IntentExample[]
  classifications       UtteranceClassification[]
}

model IntentExample {
  id        String   @id @default(cuid())
  intentId  String
  intent    Intent   @relation(fields: [intentId], references: [id], onDelete: Cascade)
  phrase    String
  createdAt DateTime @default(now())

  @@index([intentId])
}

model UtteranceClassification {
  id           String                @id @default(cuid())
  segmentId    String                @unique
  segment      CallTranscriptSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  callId       String
  intentId     String
  intent       Intent                @relation(fields: [intentId], references: [id])
  confidence   Float
  entitiesJson String                @default("{}")
  classifier   String
  debugJson    String?
  createdAt    DateTime              @default(now())

  @@index([callId])
  @@index([intentId])
}

model SalesPacket {
  id              String   @id @default(cuid())
  nameHe          String
  descriptionHe   String
  priceMonthly    Float
  contractMonths  Int      @default(12)
  active          Boolean  @default(true)
  channelIds      String   @default("[]")
  internetTierId  String?
  phonePlanId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ChannelPackage {
  id         String   @id @default(cuid())
  nameHe     String
  channels   String   @default("[]")
  priceAddon Float    @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InternetTier {
  id           String   @id @default(cuid())
  nameHe       String
  downloadMbps Int
  uploadMbps   Int
  priceMonthly Float
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PhonePlan {
  id           String   @id @default(cuid())
  nameHe       String
  features     String   @default("[]")
  priceMonthly Float
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CallFlow {
  id                 String    @id @default(cuid())
  version            Int       @default(1)
  openingTemplate    String
  stagesJson         String
  objectionsJson     String    @default("{}")
  draftGraphJson     String    @default("{}")
  publishedGraphJson String    @default("{}")
  graphPublishedAt   DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  calls              Call[]
}

model AppSettings {
  id              String   @id @default("default")
  telephonyConfig String?
  aiConfig        String?
  updatedAt       DateTime @updatedAt
}

model ProductKnowledgeIndex {
  id        String   @id @default("default")
  dataJson  String
  updatedAt DateTime @updatedAt
}

model YesCatalog {
  id          String   @id @default("default")
  catalogJson String
  scannedAt   String?
  importedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
